# ------------------------------------------------------------------
# Survey Surf — environment configuration
# Copy this file to `.env` and fill in real values for local dev.
# Every variable here is validated at startup by `lib/env.ts`.
# ------------------------------------------------------------------

# App
NODE_ENV="development"
# Public, absolute base URL. Used for canonical URLs, OG tags, sitemap.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database (PostgreSQL) — matches docker-compose.yml defaults
DATABASE_URL="postgresql://surveysurf:surveysurf@localhost:5433/surveysurf?schema=public"

# Auth.js / NextAuth
# Generate with: `openssl rand -base64 32`
AUTH_SECRET="replace-me-with-a-long-random-string"
# Optional OAuth provider (GitHub) — leave blank to disable in dev.
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
